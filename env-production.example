# Variáveis de ambiente para produção (Vercel)
# Configure estas variáveis no painel da Vercel em Settings > Environment Variables

# Chave da API Gemini (obrigatória)
VITE_GEMINI_KEY=sua_chave_gemini_aqui

# Configuração do Supabase (opcional)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_supabase_anon_aqui
